# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # solo servidor; nunca al cliente

# ─── World Office Cloud ─────────────────────────────────────
WORLD_OFFICE_ADAPTER=mock           # mock | real  (concurso = mock)
WORLD_OFFICE_BASE_URL=              # endpoint real (solo producción)
WORLD_OFFICE_LICENSE_EMAIL=         # correo_electronico_registrado
WORLD_OFFICE_ID_EMPRESA=
WORLD_OFFICE_TOKEN_REFRESH_MARGIN_MIN=60

# ─── Notificaciones / Email ─────────────────────────────────
NOTIFICATION_ADAPTER=mock           # mock | gmail
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
NOTIFICATION_TO_CONTABLE=           # correo del área contable

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
